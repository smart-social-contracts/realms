// Asset canister security policy.
// "standard" applies the dfx default headers (CSP, HSTS, X-Frame-Options,
// etc.). The Tailwind CDN script tag and esm.sh imports require a
// permissive script-src; we override to allow them while keeping the
// rest of the standard policy.
[
  {
    "match": "**/*",
    "security_policy": "standard",
    "headers": {
      "Content-Security-Policy": "default-src 'self'; script-src 'self' https: 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob:; connect-src 'self' https: wss:; font-src 'self' data: https:; frame-src https:;"
    }
  }
]
