type CodexListing = record { codex_id : text; codex_alias : text; realm_type : text; developer : text; name : text; description : text; version : text; price_e8s : nat64; icon : text; categories : text; file_registry_canister_id : text; file_registry_namespace : text; installs : nat64; likes : nat64; verification_status : text; verification_notes : text; is_active : bool; created_at : float64; updated_at : float64 };
