type GenericResult = variant { Ok : text; Err : text };
type ConfigResult = variant { Ok : ConfigRecord; Err : text };
type ExtensionResult = variant { Ok : ExtensionListing; Err : text };
type CodexResult = variant { Ok : CodexListing; Err : text };
type AssistantResult = variant { Ok : AssistantListing; Err : text };
type LicenseResult = variant { Ok : DeveloperLicense; Err : text };
type ICRCLedger = service { icrc1_balance_of : (Account) -> (nat) query; icrc1_fee : () -> (nat) query; icrc1_transfer : (TransferArg) -> (TransferResult) };
type ICRCIndexer = service { get_account_transactions : (GetAccountTransactionsRequest) -> (GetTransactionsResult) query };
type FileRegistryService = service { get_file_size_icc : (text, text) -> (text) query; get_file_chunk_icc : (text, text, text, text) -> (text) query };
type NFTService = service { mint : (MintArg) -> (MintResult) };
type RealmRegistryService = service { register_realm : (text, text, text, text, text) -> (AddRealmResult) };
type RealmTargetService = service { install_extension_from_registry : (text) -> (text); install_codex_from_registry : (text) -> (text) };
type AssetCanisterService = service { create_batch : (text) -> (text); create_chunk : (text) -> (text); commit_batch : (text) -> () };

service : {
  "status" : () -> (GetStatusResult) query;
  "list_realms" : () -> (vec RealmRecord) query;
  "register_realm" : (text, text, text, text, text) -> (AddRealmResult);
  "get_realm" : (text) -> (GetRealmResult) query;
  "remove_realm" : (text) -> (AddRealmResult);
  "search_realms" : (text) -> (vec RealmRecord) query;
  "realm_count" : () -> (nat64) query;
  "greet" : (text) -> (text) query;
  "get_credits" : (text) -> (GetCreditsResult) query;
  "add_credits" : (text, nat64, text, text) -> (AddCreditsResult);
  "deduct_credits" : (text, nat64, text) -> (DeductCreditsResult);
  "get_transactions" : (text, nat64) -> (TransactionHistoryResult) query;
  "billing_status" : () -> (GetBillingStatusResult) query;
  "request_deployment" : (text) -> (text);
  "deployment_failed" : (text, text) -> (text);
  "__get_candid_interface_tmp_hack" : () -> (text) query;
}
