service : {
  "enqueue_deployment" : (text) -> (ResultEnqueue);
  "get_pending_deployments" : () -> (ResultPendingJobs) query;
  "get_deployment_job_status" : (text) -> (ResultJobIdStatus) query;
  "list_deployment_jobs" : () -> (ResultJobsList) query;
  "list_child_canister_history" : () -> (ResultChildCanisterHistory) query;
  "cancel_deployment" : (text) -> (ResultJobCancel);
  "report_deployment_failure" : (text) -> (ResultReportFailure);
  "allocate_deployment_canisters" : (text) -> (ResultAllocate);
  "report_canister_ready" : (text) -> (ResultReportReady);
  "report_frontend_verified" : (text) -> (ResultReportFrontend);
  "verify_realm" : (text) -> (ResultVerify);
  "get_verification_report" : (text) -> (ResultVerificationReport) query;
  "execute_code_shell" : (text) -> (text);
  "debug_run_one_step" : (text) -> (ResultDebugRunStep);
  "debug_resume_deploys" : (text) -> (ResultDebugResume);
  "health" : () -> (HealthView) query;
  "info" : () -> (InstallerInfoView) query;
  "__get_candid_interface_tmp_hack" : () -> (text) query;
}
