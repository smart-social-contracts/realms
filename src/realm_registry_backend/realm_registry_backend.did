type RealmTargetService = service { install_extension_from_registry : (text) -> (text); install_codex_from_registry : (text) -> (text) };
type NFTService = service { mint : (MintArg) -> (MintResult) };
type RealmRegistryService = service { register_realm : (text, text, text, text, text) -> (AddRealmResult) };
type Ledger = service { transfer : (TransferArgs) -> (TransferResult); account_balance : (AccountBalanceArgs) -> (Tokens) query; transfer_fee : (TransferFeeArg) -> (TransferFee) query; query_blocks : (GetBlocksArgs) -> (QueryBlocksResponse) query; symbol : () -> (SymbolResult) query; name : () -> (NameResult) query; decimals : () -> (DecimalsResult) query; archives : () -> (Archives) query };
type ICRCLedger = service { icrc1_balance_of : (Account) -> (nat) query; icrc1_fee : () -> (nat) query; icrc1_transfer : (TransferArg) -> (TransferResult) };
type ICRCIndexer = service { get_account_transactions : (GetAccountTransactionsRequest) -> (GetTransactionsResult) query };
type XRCCanister = service { get_exchange_rate : (GetExchangeRateRequest) -> (GetExchangeRateResult) };
type MillisatoshiPerByte = nat64;
type ManagementCanister = service { bitcoin_get_balance : (GetBalanceArgs) -> (Satoshi); bitcoin_get_current_fee_percentiles : (GetCurrentFeePercentilesArgs) -> (vec MillisatoshiPerByte); bitcoin_get_utxos : (GetUtxosArgs) -> (GetUtxosResult); bitcoin_send_transaction : (SendTransactionArgs) -> (); create_canister : (CreateCanisterArgs) -> (CreateCanisterResult); update_settings : (UpdateSettingsArgs) -> (); install_code : (InstallCodeArgs) -> (); uninstall_code : (UninstallCodeArgs) -> (); start_canister : (StartCanisterArgs) -> (); stop_canister : (StopCanisterArgs) -> (); canister_status : (CanisterStatusArgs) -> (CanisterStatusResult); delete_canister : (DeleteCanisterArgs) -> (); deposit_cycles : (DepositCyclesArgs) -> (); raw_rand : () -> (blob); provisional_create_canister_with_cycles : (ProvisionalCreateCanisterWithCyclesArgs) -> (ProvisionalCreateCanisterWithCyclesResult); provisional_top_up_canister : (ProvisionalTopUpCanisterArgs) -> (); http_request : (HttpRequestArgs) -> (HttpResponse); ecdsa_public_key : (EcdsaPublicKeyArgs) -> (EcdsaPublicKeyResult); sign_with_ecdsa : (SignWithEcdsaArgs) -> (SignWithEcdsaResult); vetkd_public_key : (VetKDPublicKeyArgs) -> (VetKDPublicKeyResult); vetkd_derive_key : (VetKDDeriveKeyArgs) -> (VetKDDeriveKeyResult); upload_chunk : (UploadChunkArgs) -> (UploadChunkResult); clear_chunk_store : (ClearChunkStoreArgs) -> (); stored_chunks : (StoredChunksArgs) -> (vec StoredChunksResult); install_chunked_code : (InstallChunkedCodeArgs) -> () };
type TimerId = nat64;
type Duration = nat64;
type Address = text;

service : {
  "status" : () -> (GetStatusResult) query;
  "list_realms" : () -> (vec RealmRecord) query;
  "register_realm" : (text, text, text, text, text) -> (AddRealmResult);
  "get_realm" : (text) -> (GetRealmResult) query;
  "remove_realm" : (text) -> (AddRealmResult);
  "search_realms" : (text) -> (vec RealmRecord) query;
  "realm_count" : () -> (nat64) query;
  "greet" : (text) -> (text) query;
  "get_credits" : (text) -> (GetCreditsResult) query;
  "add_credits" : (text, nat64, text, text) -> (AddCreditsResult);
  "deduct_credits" : (text, nat64, text) -> (DeductCreditsResult);
  "get_transactions" : (text, nat64) -> (TransactionHistoryResult) query;
  "billing_status" : () -> (GetBillingStatusResult) query;
  "__get_candid_interface_tmp_hack" : () -> (text) query;
}
